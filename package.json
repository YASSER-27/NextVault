{
    "name": "nextvault-server",
    "private": true,
    "description": "NextVault Management App",
    "author": "yasser27",
    "version": "1.0.0",
    "main": "main.js",
    "scripts": {
        "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
        "dev:vite": "vite",
        "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
        "build": "vite build",
        "build:electron": "npm run build && electron-builder",
        "preview": "vite preview"
    },
    "build": {
        "appId": "com.yasser27.nextvault",
        "productName": "NextVault",
        "directories": {
            "output": "release"
        },
        "win": {
            "icon": "icon.png",
            "target": [
                "nsis",
                "dir"
            ],
            "extraFiles": [
                "Android",
                "media",
                "Tawasal"
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "perMachine": false
        }
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "lucide-react": "^0.344.0",
        "multer": "^2.1.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.56",
        "@types/react-dom": "^18.2.19",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.17",
        "concurrently": "^8.2.2",
        "cross-env": "^7.0.3",
        "electron": "^29.1.0",
        "electron-builder": "^24.12.0",
        "postcss": "^8.4.35",
        "tailwindcss": "^3.4.1",
        "vite": "^5.1.4",
        "wait-on": "^7.2.0"
    }
}